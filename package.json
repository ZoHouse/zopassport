{
  "name": "zopassport",
  "version": "1.0.0",
  "description": "Zo Passport SDK - Complete authentication, avatar generation, and wallet integration for Zo World applications.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.mjs",
      "require": "./dist/react.js"
    },
    "./react-native": {
      "types": "./dist/react-native.d.ts",
      "import": "./dist/react-native.mjs",
      "require": "./dist/react-native.js"
    },
    "./assets": {
      "types": "./dist/assets/index.d.ts",
      "import": "./dist/assets/index.mjs",
      "require": "./dist/assets/index.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "assets",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=16.0.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build && npm test",
    "build:cli": "cd packages/create-zopassport && npm pack",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "vitest run tests/e2e"
  },
  "dependencies": {
    "axios": "^1.6.0"
  },
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0",
    "react-native": ">=0.70.0",
    "react-native-reanimated": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "react-native": {
      "optional": true
    },
    "react-native-reanimated": {
      "optional": true
    }
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.27",
    "@types/react-dom": "^18.3.7",
    "@vitest/coverage-v8": "^4.1.0",
    "axios-mock-adapter": "^2.1.0",
    "happy-dom": "^20.8.4",
    "jsdom": "^29.0.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-native": "^0.74.0",
    "react-native-reanimated": "^4.2.0",
    "react-native-svg": "^15.15.1",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.0"
  },
  "keywords": [
    "zo",
    "zo-world",
    "passport",
    "authentication",
    "avatar",
    "phone-auth",
    "otp",
    "wallet",
    "sdk",
    "react",
    "react-native"
  ],
  "author": "Zo World Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ZoHouse/zopassport.git"
  },
  "homepage": "https://github.com/ZoHouse/zopassport#readme",
  "bugs": {
    "url": "https://github.com/ZoHouse/zopassport/issues"
  }
}
